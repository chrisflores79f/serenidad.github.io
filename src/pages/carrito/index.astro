---
const whatsapp = "593998022405";
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Carrito | Serenidad de Luna</title>
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Arial, sans-serif; background: #fffaf3; color: #2b2b2b; }
      header { background: white; padding: 18px 8%; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; }
      header a { text-decoration: none; color: #7b2d2d; font-weight: 700; }
      .container { padding: 45px 6%; }
      h1 { color: #7b2d2d; font-size: 38px; margin-bottom: 28px; }
      .empty { background: white; padding: 35px; border-radius: 10px; text-align: center; box-shadow: 0 8px 24px rgba(0,0,0,.07); }
      .empty a { display: inline-block; margin-top: 18px; background: #8b3a3a; color: white; padding: 12px 24px; border-radius: 5px; text-decoration: none; font-weight: bold; }
    </style>
  </head>
  <body>
    <header>
      <a href="/">Serenidad de Luna</a>
      <a href="/">Volver al inicio</a>
    </header>
    <main class="container">
      <h1>Carrito</h1>
      <div id="cart-content"></div>
    </main>
    <script>
      const whatsapp = "593998022405";
      const cartContent = document.getElementById("cart-content");

      function formatPrice(v) { return `$${Number(v).toFixed(2)}`; }
      function getCart() { return JSON.parse(localStorage.getItem("cart")) || []; }
      function saveCart(c) { localStorage.setItem("cart", JSON.stringify(c)); }

      function renderCart() {
        const cart = getCart();
        if (cart.length === 0) {
          cartContent.innerHTML = `<div class="empty"><h2>Tu carrito está vacío</h2><p>Agrega productos desde el catálogo.</p><a href="/">Volver al catálogo</a></div>`;
          return;
        }
        const total = cart.reduce((s, i) => s + i.price * i.quantity, 0);
        const totalItems = cart.reduce((s, i) => s + i.quantity, 0);

        cartContent.innerHTML = `
          <div style="display:grid;grid-template-columns:1fr 340px;gap:32px;align-items:start;">
            <section style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
              ${cart.map((item, index) => `
                <article style="background:white;border-radius:14px;overflow:hidden;box-shadow:0 6px 20px rgba(0,0,0,.08);display:flex;flex-direction:column;">
                  <img src="${item.image}" alt="${item.title}" style="width:100%;height:160px;object-fit:cover;display:block;background:#f2f2f2;" />
                  <div style="padding:14px 16px;">
                    <h3 style="margin:0 0 6px;font-size:15px;color:#2b2b2b;">${item.title}</h3>
                    <div style="font-weight:bold;color:#8b3a3a;margin-bottom:10px;">${formatPrice(item.price)}</div>
                    <div style="display:flex;align-items:center;gap:8px;">
                      <button class="decrease" data-index="${index}" style="width:28px;height:28px;border:1px solid #ddd;background:#fffaf3;cursor:pointer;border-radius:5px;font-weight:bold;">-</button>
                      <span style="min-width:22px;text-align:center;font-weight:bold;">${item.quantity}</span>
                      <button class="increase" data-index="${index}" style="width:28px;height:28px;border:1px solid #ddd;background:#fffaf3;cursor:pointer;border-radius:5px;font-weight:bold;">+</button>
                    </div>
                  </div>
                  <div style="padding:0 16px 14px;margin-top:auto;">
                    <div style="font-weight:bold;color:#7b2d2d;margin-bottom:8px;">${formatPrice(item.price * item.quantity)}</div>
                    <button class="remove" data-index="${index}" style="border:none;background:transparent;color:#999;cursor:pointer;font-size:13px;padding:0;">✕ Eliminar</button>
                  </div>
                </article>
              `).join("")}
            </section>

            <aside style="background:linear-gradient(160deg,#fff 0%,#fff5ea 100%);border:2px solid #b9875d;border-radius:18px;padding:28px;box-shadow:0 12px 32px rgba(123,45,45,.14);position:sticky;top:20px;">
              <h2 style="margin:0 0 18px;color:#7b2d2d;font-size:22px;font-weight:800;text-align:center;border-bottom:2px solid #e8c99a;padding-bottom:16px;letter-spacing:.5px;">🛍️ Resumen del pedido</h2>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px dashed #e0c9b0;font-size:15px;color:#555;">
                <span>Artículos</span><span style="font-weight:700;color:#2b2b2b;">${totalItems}</span>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px dashed #e0c9b0;font-size:15px;color:#555;">
                <span>Subtotal</span><span style="font-weight:700;color:#2b2b2b;">${formatPrice(total)}</span>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:18px 0 22px;font-size:22px;font-weight:800;color:#7b2d2d;">
                <span>Total</span><span>${formatPrice(total)}</span>
              </div>
              <button id="send-whatsapp" style="width:100%;border:none;background:#25D366;color:white;padding:16px;font-size:17px;font-weight:800;border-radius:10px;cursor:pointer;box-shadow:0 6px 18px rgba(37,211,102,.38);letter-spacing:.3px;">
                📱 Hacer pedido por WhatsApp
              </button>
              <p style="text-align:center;color:#999;font-size:12px;margin:14px 0 0;">Te contactaremos para confirmar tu pedido</p>
            </aside>
          </div>`;

        document.querySelectorAll(".increase").forEach(b => b.addEventListener("click", () => {
          const c = getCart(); c[+b.dataset.index].quantity += 1; saveCart(c); renderCart();
        }));
        document.querySelectorAll(".decrease").forEach(b => b.addEventListener("click", () => {
          const c = getCart();
          if (c[+b.dataset.index].quantity > 1) c[+b.dataset.index].quantity -= 1;
          saveCart(c); renderCart();
        }));
        document.querySelectorAll(".remove").forEach(b => b.addEventListener("click", () => {
          const c = getCart(); c.splice(+b.dataset.index, 1); saveCart(c); renderCart();
        }));
        document.getElementById("send-whatsapp").addEventListener("click", () => {
          const c = getCart();
          const items = c.map(i => `- ${i.title} x${i.quantity} = $${(i.price*i.quantity).toFixed(2)}`).join("%0A");
          const t = c.reduce((s,i) => s + i.price*i.quantity, 0);
          window.open(`https://wa.me/${whatsapp}?text=Hola,%20quiero%20hacer%20este%20pedido:%0A%0A${items}%0A%0ATotal:%20$${t.toFixed(2)}`, "_blank");
        });
      }

      renderCart();
    </script>
  </body>
</html>
