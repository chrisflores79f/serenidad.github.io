---
import { getCollection } from 'astro:content';

const productos = await getCollection('productos');
const whatsapp = "593 99 802 2405"; // cambia por tu número

const getImagePath = (path) => {
  if (!path) return "";
  return path.startsWith("/serenidad.github.io")
    ? path
    : `/serenidad.github.io${path}`;
};

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Serenidad de Luna</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: Arial, sans-serif;
        color: #2b2b2b;
        background: #fffaf3;
      }

     .topbar {
        background: #7b2d2d;
        color: #fffaf3;
        text-align: center;
        padding: 10px;
        font-size: 14px;
      }

     header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 8%;
        border-bottom: 1px solid #eee;
        background: #fffaf3;
        position: sticky;
        top: 0;
        z-index: 10;
      }
    .logo img {
      height: 72px;
      object-fit: contain;
      display: block;
    }
    
    @media (max-width: 900px) {
      .logo img {
        height: 56px;
      }
    }

    .logo img:hover {
        transform: scale(1.05);
      }

      nav a {
        margin-left: 30px;
        text-decoration: none;
        color: #4a2a24;
        font-weight: 600;
        font-size: 15px;
        transition: 0.2s;
      }
      
      nav a:hover {
        color: #8b3a3a;
      }

       .hero {
          min-height: 540px;
          display: flex;
          align-items: center;
          justify-content: center;
          text-align: center;
          padding: 90px 20px;
          background: linear-gradient(rgba(40, 20, 18, .58), rgba(40, 20, 18, .58)),
            url('/serenidad.github.io/images/bouquet1.png');
          background-size: cover;
          background-position: center;
          color: white;
        }

       .hero h1 {
          font-size: 56px;
          margin-bottom: 18px;
          color: white;
        }
  
      .hero h1 {
          font-size: 58px;
          margin-bottom: 18px;
          color: #fffaf3;
          text-shadow: 0 3px 14px rgba(0,0,0,.35);
        }

      .hero p {
        font-size: 21px;
        margin-bottom: 32px;
        color: #fff;
        text-shadow: 0 2px 10px rgba(0,0,0,.35);
      }

      .btn {
        display: inline-block;
        background: #8b3a3a;
        color: white;
        padding: 15px 32px;
        text-decoration: none;
        border-radius: 4px;
        font-weight: bold;
        box-shadow: 0 8px 20px rgba(0,0,0,.18);
        transition: 0.2s;
      }
      
      .btn:hover {
        background: #6f2c2c;
        transform: translateY(-2px);
      }

     .section {
        padding: 70px 8%;
        background: #fffaf3;
      }

      .section-title {
        text-align: center;
        font-size: 36px;
        margin-bottom: 42px;
        color: #7b2d2d;
        position: relative;
      }
      
      .section-title::after {
        content: "";
        display: block;
        width: 90px;
        height: 2px;
        background: #b9875d;
        margin: 14px auto 0;
      }

      .categories {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

        .category {
          height: 300px;
          background-size: cover;
          background-position: center;
          display: flex;
          align-items: center;
          justify-content: center;
          text-align: center;
          padding: 24px;
          border-radius: 6px;
          text-decoration: none;
          color: white;
          position: relative;
          overflow: hidden;
          box-shadow: 0 8px 22px rgba(0,0,0,.08);
          transition: 0.25s;
        }
        
        .category:hover {
          transform: translateY(-4px);
        }
        
        .category::before {
          content: "";
          position: absolute;
          inset: 0;
          background: rgba(65, 35, 28, .45);
        }
        
       .category h3 {
          font-size: 32px;
          margin-bottom: 10px;
          color: #ffffff;
          text-shadow: 0 3px 12px rgba(0,0,0,.65);
        }
        
        .category p {
          font-size: 16px;
          color: #ffffff;
          text-shadow: 0 2px 10px rgba(0,0,0,.65);
          font-weight: 500;
        } 
        
     


.category-velas {
  background-image: url('/serenidad.github.io/images/categoria-velas.jpg');
}

.category-jabones {
  background-image: url('/serenidad.github.io/images/categoria-jabones.jpg');
}

.category-ropa {
  background-image: url('/serenidad.github.io/images/categoria-ropa.jpg');
}

      .category h3 {
        font-size: 28px;
        margin-bottom: 10px;
      }

      .products {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
      }

      .card {
        border: 1px solid #eee;
        background: white;
        transition: .2s;
      }

      .card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,.08);
        transform: translateY(-3px);
      }

      .card img {
        width: 100%;
        height: 330px;
        object-fit: cover;
        background: #f7f7f7;
      }

      .card-content {
        padding: 22px;
      }

      .card h3 {
        font-size: 20px;
        margin-bottom: 10px;
      }

      .card p {
        font-size: 15px;
        color: #666;
        margin-bottom: 14px;
        line-height: 1.5;
      }

      .price {
        font-size: 19px;
        font-weight: bold;
        margin-bottom: 18px;
      }

      .whatsapp {
        display: block;
        text-align: center;
        background: #25D366;
        color: white;
        padding: 12px;
        text-decoration: none;
        font-weight: bold;
        border-radius: 3px;
      }

      .about {
        background: #f7f2ec;
        text-align: center;
      }

      .about p {
        max-width: 760px;
        margin: auto;
        font-size: 18px;
        line-height: 1.7;
        color: #555;
      }

      footer {
        background: #111;
        color: white;
        padding: 45px 8%;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
      }

      footer a {
        color: white;
        text-decoration: none;
      }

      @media (max-width: 900px) {
        header {
          flex-direction: column;
          gap: 15px;
        }

        nav a {
          margin: 0 8px;
        }

        .hero h1 {
          font-size: 38px;
        }

       .categories,
        .products {
          grid-template-columns: 1fr;
        }
      }

      .featured-section {
          background: #fffaf3;
          padding: 80px 8%;
        }
        
        .featured-heading {
          text-align: center;
          margin-bottom: 42px;
        }
        
        .decor-line {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 14px;
          margin-bottom: 12px;
          color: #b9875d;
        }
        
        .decor-line span:not(.leaf) {
          width: 50px;
          height: 1px;
          background: #b9875d;
          display: block;
        }
        
        .decor-line .leaf {
          color: #8b3a3a;
          font-size: 22px;
        }
        
        .featured-heading h2 {
          font-size: 40px;
          color: #7b2d2d;
          margin-bottom: 10px;
        }
        
        .featured-heading p {
          font-size: 18px;
          color: #7a5a4a;
        }
        
        .featured-products {
          display: grid;
          gap: 34px;
        }
        
        .featured-card {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 36px;
          background: white;
          border-radius: 8px;
          padding: 28px;
          box-shadow: 0 10px 28px rgba(0,0,0,.09);
          align-items: center;
        }
        
        .featured-image img {
          width: 100%;
          height: 420px;
          object-fit: cover;
          border-radius: 6px;
          display: block;
        }
        
        .featured-content {
          padding: 10px 20px;
        }
        
        .product-tag {
          display: inline-block;
          background: #c77468;
          color: white;
          padding: 7px 14px;
          border-radius: 20px;
          font-size: 12px;
          font-weight: bold;
          text-transform: uppercase;
          margin-bottom: 18px;
        }
        
        .featured-content h3 {
          font-size: 34px;
          color: #2b2b2b;
          margin-bottom: 20px;
        }
        
        .featured-content p {
          font-size: 17px;
          line-height: 1.7;
          color: #5c4a42;
          margin-bottom: 22px;
        }
        
        .featured-price {
          font-size: 28px;
          font-weight: bold;
          color: #8b3a3a;
          margin-bottom: 24px;
        }
        
        .featured-whatsapp {
          display: block;
          text-align: center;
          background: #25D366;
          color: white;
          padding: 15px;
          text-decoration: none;
          font-weight: bold;
          border-radius: 5px;
          font-size: 16px;
        }
        
        .featured-whatsapp:hover {
          background: #1ebe5d;
        }
        
        @media (max-width: 900px) {
          .featured-card {
            grid-template-columns: 1fr;
          }
        
          .featured-image img {
            height: 300px;
          }
        
          .featured-content {
            padding: 0;
          }
        
          .featured-heading h2 {
            font-size: 32px;
          }
        }

    </style>
  </head>

  <body>
    <div class="topbar">
      Compra por WhatsApp | Productos artesanales y seleccionados
    </div>

    <header>
      <div class="logo">
        <img src="/serenidad.github.io/images/logo.png" alt="Serenidad de Luna" />
      </div>
      <nav>
        <a href="#inicio">Inicio</a>
        <a href="#categorias">Categorías</a>
        <a href="#productos">Productos</a>
        <a href="#contacto">Contacto</a>
      </nav>
    </header>

    <section class="hero" id="inicio">
      <div>
        <h1>Aroma,estilo y bienestar</h1>
        <p>Velas, jabones y ropa de medio uso seleccionada con cuidado.</p>
        <a href="#productos" class="btn">Ver catálogo</a>
      </div>
    </section>

    <section class="section" id="categorias">
      <h2 class="section-title">Compra por categoría</h2>
        <div class="categories">
          <a class="category category-velas" href="/serenidad.github.io/velas/">
            <div>
              <h3>Velas</h3>
              <p>Aromas para crear momentos especiales.</p>
            </div>
          </a>
        
          <a class="category category-jabones" href="/serenidad.github.io/jabones/">
            <div>
              <h3>Jabones</h3>
              <p>Cuidado diario con un toque artesanal.</p>
            </div>
          </a>
        
          <a class="category category-ropa" href="/serenidad.github.io/ropa/">
            <div>
              <h3>Ropa medio uso</h3>
              <p>Prendas seleccionadas con estilo y conciencia.</p>
            </div>
          </a>
        </div>
      
      </div>
    </section>

      <section class="section featured-section" id="productos">
          <div class="featured-heading">
            <div class="decor-line">
              <span></span>
              <span class="leaf">❦</span>
              <span></span>
            </div>
        
            <h2>Productos destacados</h2>
            <p>Selecciones especiales que te encantarán</p>
          </div>
        
          <div class="featured-products">
            {productos.map((producto) => (
              <article class="featured-card">
                <div class="featured-image">
                  <img 
                    src={getImagePath(producto.data.imagen)} 
                    alt={producto.data.title} 
                  />
                </div>
        
                <div class="featured-content">
                  <span class="product-tag">{producto.data.categoria}</span>
                  <h3>{producto.data.title}</h3>
                  <p>{producto.data.descripcion_corta}</p>
        
                  <div class="featured-price">${producto.data.precio}</div>
        
                  <a
                    class="featured-whatsapp"
                    target="_blank"
                    href={`https://wa.me/${whatsapp}?text=Hola,%20quiero%20información%20sobre%20${encodeURIComponent(producto.data.title)}`}
                  >
                    Comprar por WhatsApp
                  </a>
                </div>
              </article>
            ))}
          </div>
        </section>

    <section class="section about">
      <h2 class="section-title">Sobre Serenidad de Luna</h2>
      <p>
        Somos una marca pensada para quienes buscan detalles especiales,
        productos con encanto y compras conscientes. Ofrecemos velas,
        jabones y ropa de medio uso cuidadosamente seleccionada.
      </p>
    </section>

    <footer id="contacto">
      <div>
        <h3>Serenidad de Luna</h3>
        <p>Velas, jabones y ropa medio uso.</p>
      </div>

      <div>
        <h3>Contacto</h3>
        <p>WhatsApp: +593 99 802 2405</p>
        <p>Instagram: @serenidaddeluna</p>
      </div>
    </footer>
  </body>
</html>
